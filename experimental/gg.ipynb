    "def use_direction(cls):\n",
    "    cls._use_direction = True\n",
    "    return cls\n",
    "\n",
    "def true_if_direction(cls):\n",
    "    print(cls._x if cls._use_direction else False)\n",
    "\n",
    "\n",
    "@use_direction\n",
    "class Foo:\n",
    "    @true_if_direction\n",
    "    def __init__(self, x):\n",
    "        self.x = x\n"
